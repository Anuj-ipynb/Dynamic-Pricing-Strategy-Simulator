# =========================================================
# BASE IMAGE
# =========================================================
FROM python:3.10-slim

# =========================================================
# WORK DIRECTORY
# =========================================================
WORKDIR /app

ENV PYTHONPATH=/app

# =========================================================
# COPY REQUIREMENTS
# =========================================================
COPY requirements.txt .

# =========================================================
# INSTALL DEPENDENCIES
# =========================================================
RUN pip install --no-cache-dir -r requirements.txt

# =========================================================
# COPY PROJECT FILES
# =========================================================
COPY . .

# =========================================================
# CREATE DIRECTORIES
# =========================================================
RUN mkdir -p artifacts/models \
    artifacts/history \
    artifacts/metadata \
    artifacts/plots \
    experiments \
    mlruns

# =========================================================
# EXPOSE PORT
# =========================================================
EXPOSE 8000

# =========================================================
# DEFAULT COMMAND
# =========================================================
CMD ["python", "training/train.py"]