# =========================================================
# PYTHON
# =========================================================
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
ENV/

# Python packaging
build/
dist/
*.egg-info/
.eggs/

# =========================================================
# JUPYTER
# =========================================================
.ipynb_checkpoints/

# =========================================================
# IDE / EDITOR
# =========================================================
.vscode/
.idea/
*.swp
*.swo

# =========================================================
# OS FILES
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# LOGS
# =========================================================
*.log

# =========================================================
# ENVIRONMENT VARIABLES
# =========================================================
.env
.env.*

# =========================================================
# NODE / FRONTEND
# =========================================================
frontend/node_modules/
frontend/dist/

# Vite cache
frontend/.vite/

# =========================================================
# ARTIFACTS
# =========================================================

# Keep directory structure
artifacts/*
!artifacts/.gitkeep

# Keep subdirectories tracked
!artifacts/models/
!artifacts/plots/
!artifacts/history/
!artifacts/metadata/

# Ignore generated contents
artifacts/models/*
artifacts/plots/*
artifacts/history/*
artifacts/metadata/*

# Keep folders alive
!artifacts/models/.gitkeep
!artifacts/plots/.gitkeep
!artifacts/history/.gitkeep
!artifacts/metadata/.gitkeep

# =========================================================
# EXPERIMENT OUTPUTS
# =========================================================
experiments/results.csv

# =========================================================
# TRAINING OUTPUTS
# =========================================================
*.pt
*.pth

# =========================================================
# GENERATED MEDIA
# =========================================================
*.png
*.jpg
*.jpeg
*.gif
*.svg

# =========================================================
# CACHE
# =========================================================
.cache/
.pytest_cache/

# =========================================================
# MISC
# =========================================================
*.tmp
*.temp