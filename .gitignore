# =========================================================
# PYTHON
# =========================================================
__pycache__/
*.py[cod]
*$py.class

# =========================================================
# VIRTUAL ENVIRONMENTS
# =========================================================
venv/
.venv/
env/
ENV/

# =========================================================
# PYTHON PACKAGING
# =========================================================
build/
dist/
*.egg-info/
.eggs/

# =========================================================
# JUPYTER
# =========================================================
.ipynb_checkpoints/

# =========================================================
# IDE / EDITOR
# =========================================================
.vscode/
.idea/
*.swp
*.swo

# =========================================================
# OS FILES
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# LOGS
# =========================================================
*.log

# =========================================================
# ENVIRONMENT VARIABLES
# =========================================================
.env
.env.*

# =========================================================
# NODE / FRONTEND
# =========================================================
frontend/node_modules/
frontend/dist/
frontend/.vite/

# =========================================================
# MLFLOW
# =========================================================
mlruns/
mlartifacts/
*.db

# =========================================================
# ARTIFACTS
# =========================================================

# Ignore generated artifacts
artifacts/history/*
artifacts/plots/*
artifacts/metadata/*

# Keep directories alive
!artifacts/history/.gitkeep
!artifacts/plots/.gitkeep
!artifacts/metadata/.gitkeep

# =========================================================
# MODEL FILES
# =========================================================

# Ignore all model weights globally
*.pt
*.pth

# BUT keep trained models inside artifacts/models
!artifacts/models/
!artifacts/models/*.pt
!artifacts/models/*.pth

# =========================================================
# EXPERIMENT OUTPUTS
# =========================================================
experiments/results.csv

# =========================================================
# GENERATED MEDIA
# =========================================================
*.png
*.jpg
*.jpeg
*.gif
*.svg

# Keep important report/demo plots if needed
!artifacts/plots/*.png

# =========================================================
# CACHE
# =========================================================
.cache/
.pytest_cache/

# =========================================================
# TORCH / CUDA
# =========================================================
*.ckpt

# =========================================================
# TEMP FILES
# =========================================================
*.tmp
*.temp

# =========================================================
# MISC
# =========================================================
coverage/
htmlcov/